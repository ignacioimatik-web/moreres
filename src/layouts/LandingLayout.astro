---
import BaseLayout from "./BaseLayout.astro"

export interface Props {
  title: string
  description: string
  ogImage?: string
  ogType?: string
  robots?: string
  breadcrumbs?: { label: string; href: string }[]
}

const { title, description, ogImage, ogType, robots, breadcrumbs } = Astro.props
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType={ogType}
  robots={robots}
  breadcrumbs={breadcrumbs}
>
  <slot />
</BaseLayout>
