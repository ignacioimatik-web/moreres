---
import Footer from "@/components/Footer.astro"
import SidebarNavigation from "@/components/SidebarNavigation.astro"
import MobileNavigationDrawer from "@/components/MobileNavigationDrawer.astro"
import { defaultSEO, organization, localBusiness } from "@data/seo"
import { getBreadcrumbs } from "@data/navigation"

export interface Props {
  title: string
  description: string
  ogImage?: string
  ogType?: string
  robots?: string
  breadcrumbs?: { label: string; href: string }[]
}

const {
  title: pageTitle,
  description,
  ogImage,
  ogType = "website",
  robots = "index, follow",
  breadcrumbs: explicitBreadcrumbs,
} = Astro.props

const siteUrl = "https://asociacionmoreres.org"
const canonical = Astro.url.pathname
const title = pageTitle.includes("|") ? pageTitle : `${pageTitle} | Asociación Moreres`
const image = ogImage || defaultSEO.ogImage
const imageUrl = image.startsWith("http") ? image : `${siteUrl}${image}`

const breadcrumbs = explicitBreadcrumbs ?? getBreadcrumbs(canonical)
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />

    <link rel="canonical" href={`${siteUrl}${canonical}`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={`${siteUrl}${canonical}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Asociación Moreres" />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet" />

    <!-- Styles -->
    <link rel="stylesheet" href="/styles/tokens.css" />
    <link rel="stylesheet" href="/styles/base.css" />
    <link rel="stylesheet" href="/styles/components.css" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...organization })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      url: siteUrl,
      name: "Asociación Moreres",
      description: defaultSEO.description,
      inLanguage: "es",
      publisher: { "@id": `${siteUrl}/#organization` },
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({ "@context": "https://schema.org", ...localBusiness })} />
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: crumb.label,
          item: `${siteUrl}${crumb.href}`,
        })),
      })} />
    )}
  </head>
  <body>
    <div class="app-shell">
      <SidebarNavigation />

      <div class="app-shell__main">
        <header class="mobile-topbar">
          <a href="/" class="mobile-topbar__brand" aria-label="Inicio Moreres">
            <img src="/assets/logos/moreres-logo-morera-letras.png" alt="Moreres" width="32" height="32" />
            <span>Moreres</span>
          </a>
          <MobileNavigationDrawer />
        </header>

        <main>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>

<style>
  .app-shell {
    min-height: 100vh;
  }

  .app-shell__main {
    min-width: 0;
    background: var(--surface-white);
  }

  .mobile-topbar {
    position: sticky;
    top: 0;
    z-index: 45;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-3);
    padding: 0 var(--spacing-5);
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--color-neutral-100);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .mobile-topbar__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-3);
    color: var(--text-primary);
    font-weight: var(--font-semibold);
  }

  @media (min-width: 1024px) {
    .app-shell {
      display: grid;
      grid-template-columns: var(--sidebar-width, 280px) 1fr;
    }

    .mobile-topbar {
      display: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          if (entry.target.classList.contains("reveal-children")) {
            entry.target.classList.add("reveal-children--visible")
          } else {
            entry.target.classList.add("reveal--visible")
          }
          observer.unobserve(entry.target)
        }
      }
    },
    { threshold: 0.1, rootMargin: "0px 0px -40px 0px" }
  )

  document.querySelectorAll(".reveal, .reveal-children").forEach((el) => observer.observe(el))
</script>
