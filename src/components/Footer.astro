---
import { footerLinks } from "@data/navigation"
---

<footer class="footer" role="contentinfo">
  <div class="footer__grid">
    <div class="footer__brand">
      <div class="footer__logo">
        <img src="/assets/logos/moreres-logo-morera-letras.png" alt="ASOCIACIÓN MORERES" width="40" height="40" />
      </div>
      <p class="footer__description">
        Asociación Juvenil, Castellón (1971). Un proyecto educativo que ayuda a los padres en la formación de sus hijos.
      </p>
      <div class="footer__social">
        <a href="https://www.facebook.com/asociacionmoreres" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.instagram.com/asociacionmoreres" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" fill="none" stroke="currentColor" stroke-width="2"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5" stroke="currentColor" stroke-width="2"/></svg>
        </a>
        <a href="https://www.youtube.com/@asociacionmoreres" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.94 2C5.12 20 12 20 12 20s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98" fill="currentColor"/></svg>
        </a>
        <a href="https://twitter.com/moreres_cd" class="footer__social-link" target="_blank" rel="noopener noreferrer" aria-label="Twitter/X">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4l6.25 8.5L4 20h2.5l5-5.5L15.5 20H20l-6.5-9L19.5 4H17l-4.5 5L8 4H4z"/></svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="footer__title">{footerLinks.association.label}</h3>
      <ul class="footer__list">
        {footerLinks.association.items.map((item) => (
          <li><a href={item.href} class="footer__link">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="footer__title">{footerLinks.activities.label}</h3>
      <ul class="footer__list">
        {footerLinks.activities.items.map((item) => (
          <li><a href={item.href} class="footer__link">{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="footer__title">{footerLinks.resources.label}</h3>
      <ul class="footer__list">
        {footerLinks.resources.items.map((item) => (
          <li><a href={item.href} class="footer__link">{item.label}</a></li>
        ))}
      </ul>
      <h3 class="footer__title" style="margin-top: 1.5rem">{footerLinks.legal.label}</h3>
      <ul class="footer__list">
        {footerLinks.legal.items.map((item) => (
          <li><a href={item.href} class="footer__link">{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__copyright">
        &copy; {new Date().getFullYear()} Asociación Moreres. C/ Cronista Revest N.1-Bajo, 12003 Castellón.
      </p>
      <ul class="footer__legal">
        {footerLinks.legal.items.map((item) => (
          <li><a href={item.href} class="footer__legal-link">{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>
