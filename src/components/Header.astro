---
import { navigation } from "@data/navigation"

const currentPath = Astro.url.pathname

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/"
  return currentPath.startsWith(href)
}
---

<header class="header" id="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Inicio - Asociación Moreres">
      <img src="/assets/logos/moreres-logo-morera-letras.png" alt="ASOCIACIÓN MORERES" width="40" height="40" />
    </a>

    <nav class="nav" aria-label="Navegación principal">
      <ul class="nav__list">
        {
          navigation.map((item) => (
            <li class="nav__item">
              {item.children ? (
                <>
                  <a
                    href={item.href}
                    class:list={["nav__link", { "nav__link--active": isActive(item.href) }]}
                  >
                    {item.label}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </a>
                  <div class="nav__dropdown" role="menu">
                    {item.children.map((child) => (
                      <a href={child.href} class="nav__dropdown-item" role="menuitem">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </>
              ) : (
                <a
                  href={item.href}
                  class:list={["nav__link", {
                    "nav__link--highlighted": item.isHighlighted,
                    "nav__link--active": isActive(item.href) && !item.isHighlighted
                  }]}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <button class="nav-toggle" type="button" id="navToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobileMenu">
      <svg class="nav-toggle__icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu" role="navigation" aria-label="Navegación móvil">
    <div class="mobile-menu__panel">
      <div class="mobile-menu__header">
        <span>Menú</span>
        <button class="mobile-menu__close" id="mobileMenuClose" type="button" aria-label="Cerrar menú">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" /></svg>
        </button>
      </div>
      <ul class="mobile-menu__list">
        {
          navigation.map((item) => (
            <li class="mobile-menu__item">
              <a href={item.href} class="mobile-menu__link" data-mobile-link>{item.label}</a>
              {item.children && (
                <ul class="mobile-menu__sublist">
                  {item.children.map((child) => (
                    <li><a href={child.href} class="mobile-menu__sublink" data-mobile-link>{child.label}</a></li>
                  ))}
                </ul>
              )}
            </li>
          ))
        }
      </ul>
    </div>
    <button class="mobile-menu__overlay" type="button" id="mobileMenuOverlay" aria-label="Cerrar menú"></button>
  </div>
</header>

<script>
  const header = document.getElementById("header")
  const navToggle = document.getElementById("navToggle")
  const mobileMenu = document.getElementById("mobileMenu")
  const mobileMenuClose = document.getElementById("mobileMenuClose")
  const mobileMenuOverlay = document.getElementById("mobileMenuOverlay")
  const mobileLinks = document.querySelectorAll("[data-mobile-link]")
  let mobileOpen = false

  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.classList.add("header--scrolled")
    } else {
      header?.classList.remove("header--scrolled")
    }
    closeAllDropdowns()
  }

  const closeAllDropdowns = () => {
    document.querySelectorAll(".nav__item--open").forEach((el) => {
      el.classList.remove("nav__item--open")
    })
  }

  const setMobileMenu = (open) => {
    mobileOpen = open
    mobileMenu?.classList.toggle("is-open", open)
    navToggle?.setAttribute("aria-expanded", String(open))
    document.documentElement.classList.toggle("mobile-menu-open", open)
  }

  const positionDropdown = (dropdown, link) => {
    const rect = link.getBoundingClientRect()
    dropdown.style.position = "fixed"
    dropdown.style.top = rect.bottom + "px"
    dropdown.style.left = rect.left + rect.width / 2 + "px"
    dropdown.style.transform = "translateX(-50%)"
    dropdown.style.marginTop = "0"
  }

  window.addEventListener("scroll", handleScroll, { passive: true })

  document.querySelectorAll(".nav__item > a").forEach((link) => {
    link.addEventListener("click", (e) => {
      const parent = link.parentElement
      if (!parent) return
      const hasChildren = parent.querySelector(".nav__dropdown")
      if (!hasChildren) return
      const alreadyOpen = parent.classList.contains("nav__item--open")
      closeAllDropdowns()
      if (!alreadyOpen) {
        parent.classList.add("nav__item--open")
        const dropdown = parent.querySelector(".nav__dropdown")
        if (dropdown) positionDropdown(dropdown, link)
        e.preventDefault()
      }
    })
  })

  document.addEventListener("click", (e) => {
    if (!e.target || !(e.target instanceof Element)) return
    if (!e.target.closest(".nav__item")) {
      closeAllDropdowns()
    }
  })

  navToggle?.addEventListener("click", () => setMobileMenu(!mobileOpen))
  mobileMenuClose?.addEventListener("click", () => setMobileMenu(false))
  mobileMenuOverlay?.addEventListener("click", () => setMobileMenu(false))
  mobileLinks.forEach((link) => link.addEventListener("click", () => setMobileMenu(false)))

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeAllDropdowns()
      setMobileMenu(false)
    }
  })

  window.addEventListener("resize", closeAllDropdowns)
</script>
