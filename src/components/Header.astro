---
import { navigation } from "@data/navigation"

const currentPath = Astro.url.pathname

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/"
  return currentPath.startsWith(href)
}
---

<header class="header" id="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Inicio - Asociación Moreres">
      <img src="/assets/logos/moreres-logo-morera-letras.png" alt="ASOCIACIÓN MORERES" width="40" height="40" />
    </a>

    <button class="nav-toggle" id="navToggle" aria-label="Menú" aria-expanded="false">
      <svg class="nav-toggle__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <nav class="nav" aria-label="Navegación principal">
      <ul class="nav__list">
        {
          navigation.map((item) => (
            <li class="nav__item">
              {item.children ? (
                <>
                  <a
                    href={item.href}
                    class:list={["nav__link", { "nav__link--active": isActive(item.href) }]}
                  >
                    {item.label}
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                  </a>
                  <div class="nav__dropdown" role="menu">
                    {item.children.map((child) => (
                      <a href={child.href} class="nav__dropdown-item" role="menuitem">
                        {child.label}
                      </a>
                    ))}
                  </div>
                </>
              ) : (
                <a
                  href={item.href}
                  class:list={["nav__link", {
                    "nav__link--highlighted": item.isHighlighted,
                    "nav__link--active": isActive(item.href) && !item.isHighlighted
                  }]}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="nav-overlay" id="navOverlay">
    <ul class="nav-overlay__list">
      {
        navigation.map((item) => (
          <li class="nav-overlay__item">
            <a
              href={item.href}
              class:list={["nav-overlay__link", { "nav-overlay__link--highlighted": item.isHighlighted }]}
              data-overlay-link
            >
              {item.label}
            </a>
            {item.children && (
              <ul class="nav-overlay__sublist">
                {item.children.map((child) => (
                  <li>
                    <a href={child.href} class="nav-overlay__sublink" data-overlay-link>
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById("header")
  const navToggle = document.getElementById("navToggle")
  const navOverlay = document.getElementById("navOverlay")
  const overlayLinks = document.querySelectorAll("[data-overlay-link]")
  let isOpen = false

  const handleScroll = () => {
    if (window.scrollY > 50) {
      header?.classList.add("header--scrolled")
    } else {
      header?.classList.remove("header--scrolled")
    }
  }

  const toggleOverlay = () => {
    isOpen = !isOpen
    navOverlay?.classList.toggle("nav-overlay--open")
    navToggle?.setAttribute("aria-expanded", String(isOpen))
    document.body.style.overflow = isOpen ? "hidden" : ""
  }

  window.addEventListener("scroll", handleScroll, { passive: true })
  navToggle?.addEventListener("click", toggleOverlay)
  overlayLinks.forEach((link) => {
    link.addEventListener("click", () => {
      if (isOpen) toggleOverlay()
    })
  })

  document.querySelectorAll(".nav__item > a").forEach((link) => {
    link.addEventListener("click", (e) => {
      const parent = link.parentElement
      if (!parent) return
      const hasChildren = parent.querySelector(".nav__dropdown")
      if (!hasChildren) return
      const alreadyOpen = parent.classList.contains("nav__item--open")
      document.querySelectorAll(".nav__item--open").forEach((el) => {
        el.classList.remove("nav__item--open")
      })
      if (!alreadyOpen) {
        parent.classList.add("nav__item--open")
        e.preventDefault()
      }
    })
  })

  document.addEventListener("click", (e) => {
    if (!e.target || !(e.target instanceof Element)) return
    if (!e.target.closest(".nav__item")) {
      document.querySelectorAll(".nav__item--open").forEach((el) => {
        el.classList.remove("nav__item--open")
      })
    }
  })
</script>
