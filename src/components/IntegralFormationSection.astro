---
export interface CardData {
  title: string
  description: string
  mediaType: "image" | "video"
  mediaSrc: string
  fallbackImage: string
  icon: string
  href?: string
}

const cards: CardData[] = [
  {
    title: "Formación humana",
    description: "Programa de virtudes para un desarrollo pleno: sinceridad, lealtad, fortaleza, paciencia, generosidad.",
    mediaType: "image",
    mediaSrc: "/assets/images/rafa-lafuente-1_orig.jpg",
    fallbackImage: "/assets/images/rafa-lafuente-1_orig.jpg",
    icon: "pen",
    href: "/quienes-somos/proyecto-educativo",
  },
  {
    title: "Amistad",
    description: "Moreres es un modo de convivir, de pasarlo bien, de tener amigos. El Club es una segunda casa.",
    mediaType: "image",
    mediaSrc: "/assets/gallery/community-1.jpg",
    fallbackImage: "/assets/gallery/community-1.jpg",
    icon: "users",
    href: "/quienes-somos/que-es-moreres",
  },
  {
    title: "Estudio",
    description: "Salas de estudio con profesor cualificado. De lunes a jueves, de 5º Primaria a 2º Bachillerato.",
    mediaType: "image",
    mediaSrc: "/assets/images/estudio-3_orig.jpg",
    fallbackImage: "/assets/images/estudio-3_orig.jpg",
    icon: "book",
    href: "/actividades/estudio",
  },
  {
    title: "Familia",
    description: "La asociación surge por iniciativa de las familias. Planes familiares, formación padres y programa de virtudes.",
    mediaType: "image",
    mediaSrc: "/assets/gallery/convivencia-familiar-1.jpg",
    fallbackImage: "/assets/gallery/convivencia-familiar-1.jpg",
    icon: "home",
    href: "/actividades/familias",
  },
  {
    title: "Deporte",
    description: "Escuela Deportiva de fútbol desde 1996. Once equipos federados. Formamos personas a través del deporte.",
    mediaType: "image",
    mediaSrc: "/assets/images/supercopa-2023_orig.jpeg",
    fallbackImage: "/assets/images/supercopa-2023_orig.jpeg",
    icon: "sports",
    href: "/escuela-deportiva",
  },
  {
    title: "Solidaridad",
    description: "Visitas a residencias, donación de alimentos, acompañamiento. Aprendemos a estar pendientes de los demás.",
    mediaType: "image",
    mediaSrc: "/assets/gallery/visita-residencial-castell-n-2.jpg",
    fallbackImage: "/assets/gallery/visita-residencial-castell-n-2.jpg",
    icon: "heart",
    href: "/actividades/solidaridad",
  },
]
---

<section class="integral-formation section reveal">
  <div class="container">
    <header class="integral-formation__header">
      <span class="tagline tagline--center">Formación integral</span>
      <h2 class="integral-formation__title">Un club para crecer</h2>
      <div class="separator separator--center" />
      <p class="integral-formation__text">
        Ofrecemos un conjunto de actividades en las que, en un ambiente de trabajo, amistad y confianza,
        se lo pasen bien a la vez que mejoren como personas.
      </p>
    </header>

    <div class="formation-grid reveal-children">
      {
        cards.map((card, i) => (
          <a
            href={card.href ?? "#"}
            class="formation-card"
            style={`--card-index: ${i}`}
          >
            <div class="formation-card__media">
              {
                card.mediaType === "video" ? (
                  <video
                    src={card.mediaSrc}
                    poster={card.fallbackImage}
                    autoplay
                    muted
                    loop
                    playsInline
                    aria-hidden="true"
                    class="formation-card__video"
                  >
                    <img src={card.fallbackImage} alt="" aria-hidden="true" loading="lazy" />
                  </video>
                ) : (
                  <img
                    src={card.mediaSrc}
                    alt=""
                    aria-hidden="true"
                    loading="lazy"
                    class="formation-card__image"
                  />
                )
              }
            </div>
            <div class="formation-card__overlay" />
            <div class="formation-card__content">
              <div class="formation-card__icon" aria-hidden="true">
                {
                  card.icon === "pen" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  )
                }
                {
                  card.icon === "users" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                  )
                }
                {
                  card.icon === "book" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                  )
                }
                {
                  card.icon === "home" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                  )
                }
                {
                  card.icon === "sports" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  )
                }
                {
                  card.icon === "heart" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  )
                }
              </div>
              <h3 class="formation-card__title">{card.title}</h3>
              <p class="formation-card__text">{card.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .integral-formation {
    background: var(--surface-light);
  }

  .integral-formation__header {
    text-align: center;
    margin-bottom: var(--spacing-12);
  }

  .integral-formation__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    color: var(--text-primary);
  }

  .integral-formation__text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 768px) {
    .integral-formation__title {
      font-size: var(--text-4xl);
    }
  }

  .formation-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-5);
  }

  @media (min-width: 640px) {
    .formation-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .formation-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .formation-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    text-decoration: none;
    cursor: pointer;
    border: 1px solid var(--color-neutral-100);
    transition: box-shadow var(--duration-normal) var(--easing-default), transform var(--duration-normal) var(--easing-default);
  }

  .formation-card:hover {
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .formation-card:focus-visible {
    outline: 2px solid var(--color-primary-500);
    outline-offset: 2px;
  }

  .formation-card__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .formation-card__image,
  .formation-card__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--easing-default);
  }

  .formation-card:hover .formation-card__image,
  .formation-card:hover .formation-card__video {
    transform: scale(1.06);
  }

  .formation-card__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(31, 33, 31, 0.1) 0%,
      rgba(31, 33, 31, 0.3) 40%,
      rgba(31, 33, 31, 0.75) 80%,
      rgba(31, 33, 31, 0.9) 100%
    );
    transition: background var(--duration-normal) var(--easing-default);
  }

  .formation-card:hover .formation-card__overlay {
    background: linear-gradient(
      180deg,
      rgba(31, 33, 31, 0.15) 0%,
      rgba(31, 33, 31, 0.4) 40%,
      rgba(31, 33, 31, 0.85) 80%,
      rgba(31, 33, 31, 0.95) 100%
    );
  }

  .formation-card__content {
    position: relative;
    z-index: 2;
    padding: var(--spacing-8);
  }

  .formation-card__icon {
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    border-radius: var(--radius-lg);
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--spacing-4);
    transition: background var(--duration-fast) var(--easing-default), transform var(--duration-fast) var(--easing-default);
  }

  .formation-card__icon svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .formation-card:hover .formation-card__icon {
    background: rgba(255, 255, 255, 0.25);
    transform: scale(1.05);
  }

  .formation-card__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--text-inverse);
    margin-bottom: var(--spacing-2);
  }

  .formation-card__text {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.8);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  @media (max-width: 639px) {
    .formation-card {
      min-height: 280px;
    }

    .formation-card__content {
      padding: var(--spacing-6);
    }

    .formation-card__title {
      font-size: var(--text-lg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .formation-card,
    .formation-card__image,
    .formation-card__video,
    .formation-card__overlay,
    .formation-card__icon {
      transition: none;
    }

    .formation-card:hover {
      transform: none;
    }

    .formation-card:hover .formation-card__image,
    .formation-card:hover .formation-card__video {
      transform: none;
    }
  }
</style>
