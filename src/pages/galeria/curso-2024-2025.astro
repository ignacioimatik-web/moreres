---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import Gallery from "@/components/Gallery.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Curso 2024-2025 | Galería Moreres",
  description: "Imágenes de actividades del curso 2024-2025."
}
const breadcrumbs = getBreadcrumbs("/galeria/curso-2024-2025")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Curso 2024-2025" subtitle="Galería de imágenes" breadcrumbs={breadcrumbs} />

  <Section>
    <Gallery
      images={[
        { src: "/assets/gallery/cartel-temporada-2023-2024.png", alt: "Cartel de la temporada 2024-2025" },
        { src: "/assets/gallery/community-1.jpg", alt: "Actividad comunitaria" },
        { src: "/assets/gallery/community-2.jpg", alt: "Actividad comunitaria" },
        { src: "/assets/gallery/community-3.jpg", alt: "Actividad comunitaria" },
        { src: "/assets/gallery/community-5.jpg", alt: "Actividad comunitaria" },
        { src: "/assets/gallery/community-7.jpg", alt: "Actividad comunitaria" },
      ]}
    />
  </Section>
</BaseLayout>
