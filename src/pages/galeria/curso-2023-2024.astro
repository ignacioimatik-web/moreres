---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import Gallery from "@/components/Gallery.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Curso 2023-2024 | Galería Moreres",
  description: "Imágenes de actividades del curso 2023-2024."
}
const breadcrumbs = getBreadcrumbs("/galeria/curso-2023-2024")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Curso 2023-2024" subtitle="Galería de imágenes" breadcrumbs={breadcrumbs} />

  <Section>
    <Gallery
      images={[
        { src: "/assets/gallery/convivencia-familiar-1.jpg", alt: "Convivencia familiar" },
        { src: "/assets/gallery/convivencia-familiar-2.jpg", alt: "Convivencia familiar" },
        { src: "/assets/gallery/convivencia-familiar-3.jpg", alt: "Convivencia familiar" },
        { src: "/assets/gallery/convivencia-familiar-4.jpg", alt: "Convivencia familiar" },
        { src: "/assets/gallery/familias.jpg", alt: "Familias" },
        { src: "/assets/gallery/villancicos-familias.jpg", alt: "Villancicos con las familias" },
        { src: "/assets/gallery/img-20240330-wa0012.jpg", alt: "Actividad de Semana Santa" },
        { src: "/assets/gallery/img-20240331-wa0008.jpg", alt: "Actividad de Semana Santa" },
      ]}
    />
  </Section>
</BaseLayout>
