---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import Gallery from "@/components/Gallery.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Curso 2020-2021 | Galería Moreres",
  description: "Imágenes de actividades del curso 2020-2021."
}
const breadcrumbs = getBreadcrumbs("/galeria/curso-2020-2021")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Curso 2020-2021" subtitle="Galería de imágenes" breadcrumbs={breadcrumbs} />

  <Section>
    <Gallery
      images={[
        { src: "/assets/gallery/septiembre-1-2022.png", alt: "Septiembre 2022" },
        { src: "/assets/gallery/octubre-1-2022.png", alt: "Octubre 2022" },
        { src: "/assets/gallery/noviembre-1-2022.png", alt: "Noviembre 2022" },
        { src: "/assets/gallery/diciembre-1-2022.png", alt: "Diciembre 2022" },
        { src: "/assets/gallery/convivencia-murcia_orig.jpg", alt: "Convivencia Murcia" },
        { src: "/assets/gallery/fb-img-1687854557625.jpg", alt: "Actividad" },
        { src: "/assets/gallery/hablar-en-p-blico-1.jpg", alt: "Taller hablar en público" },
        { src: "/assets/gallery/hablar-en-p-blico-2.jpg", alt: "Taller hablar en público" },
      ]}
    />
  </Section>
</BaseLayout>
