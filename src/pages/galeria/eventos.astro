---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import Gallery from "@/components/Gallery.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Eventos especiales | Galería Moreres",
  description: "Eventos especiales de Moreres: Star Wars, World Cup, viaje a Fátima, Jornada de la Familia, Romería y más."
}
const breadcrumbs = getBreadcrumbs("/galeria/eventos")
