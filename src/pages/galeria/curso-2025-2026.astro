---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import Gallery from "@/components/Gallery.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Curso 2025-2026 | Galería Moreres",
  description: "Imágenes de actividades del curso 2025-2026."
}
const breadcrumbs = getBreadcrumbs("/galeria/curso-2025-2026")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Curso 2025-2026" subtitle="Galería de imágenes" breadcrumbs={breadcrumbs} />

  <Section>
    <Gallery
      images={[
        { src: "/assets/gallery/cartel-temporada-2025-2026_orig.png", alt: "Cartel de la temporada 2025-2026" },
        { src: "/assets/gallery/c-d-moreres-2024-2025_orig.png", alt: "C D Moreres 2024-2025" },
        { src: "/assets/gallery/cena-de-navidad-2025-2.jpg", alt: "Cena de Navidad 2025" },
        { src: "/assets/gallery/cena-de-navidad-2025-3.jpg", alt: "Cena de Navidad 2025" },
        { src: "/assets/gallery/cena-de-navidad-2025-4.jpg", alt: "Cena de Navidad 2025" },
        { src: "/assets/gallery/cena-de-navidad-2025-5.jpg", alt: "Cena de Navidad 2025" },
      ]}
    />
  </Section>
</BaseLayout>
