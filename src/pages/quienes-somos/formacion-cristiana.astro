---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Formación cristiana | Asociación Moreres",
  description: "Formación espiritual, charlas, meditaciones y cursos de retiro."
}
const breadcrumbs = getBreadcrumbs("/quienes-somos/formacion-cristiana")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader
    title="Formación cristiana"
    subtitle="Crecimiento espiritual y acompañamiento personal"
    breadcrumbs={breadcrumbs}
  />

  <Section tagline="Dimensión espiritual" title="Aspirar a los bienes más altos">
    <div class="content-block">
      <p class="content-block__text">
        La formación cristiana es una parte fundamental del proyecto educativo de Moreres. Laicos y
        sacerdotes de la Prelatura del Opus Dei se encargan de esta tarea, ofreciendo los medios
        necesarios para el crecimiento espiritual de cada socio.
      </p>
    </div>
  </Section>

  <Section variant="light" tagline="Actividades" title="Medios de formación">
    <div class="activities-list">
      <div class="activity-item">
        <div class="activity-item__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
        </div>
        <div>
          <h3 class="activity-item__title">Charlas de formación cristiana</h3>
          <p class="activity-item__text">Charlas periódicas adaptadas a cada edad para profundizar en la fe.</p>
        </div>
      </div>
      <div class="activity-item">
        <div class="activity-item__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div>
          <h3 class="activity-item__title">Meditaciones semanales</h3>
          <p class="activity-item__text">Espacios de reflexión y oración para la vida cristiana de cada uno.</p>
        </div>
      </div>
      <div class="activity-item">
        <div class="activity-item__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
        </div>
        <div>
          <h3 class="activity-item__title">Cursos de retiro</h3>
          <p class="activity-item__text">Convivencias y retiros espirituales para profundizar en la vida interior.</p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .content-block {
    max-width: 720px;
    margin: 0 auto;
  }

  .content-block__text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }

  .activities-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-6);
    max-width: 640px;
    margin: 0 auto;
  }

  .activity-item {
    display: flex;
    gap: var(--spacing-4);
    padding: var(--spacing-5);
    background: var(--surface-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-neutral-100);
  }

  .activity-item__icon {
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-50);
    border-radius: var(--radius-lg);
    color: var(--color-primary-500);
  }

  .activity-item__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--font-bold);
    margin-bottom: var(--spacing-1);
    color: var(--text-primary);
  }

  .activity-item__text {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }
</style>
