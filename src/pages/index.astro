---
import LandingLayout from "@/layouts/LandingLayout.astro"
import IntegralFormationSection from "@/components/IntegralFormationSection.astro"
import { pages } from "@data/seo"

const route = pages["/"]
---

<LandingLayout title={route.title} description={route.description} ogImage={route.ogImage}>
  <!-- ============================================ -->
  <!-- BLOQUE 1: HERO PRINCIPAL                    -->
  <!-- ============================================ -->
  <section class="hero" aria-label="Hero principal">
    <div class="hero__background">
      <img src="/assets/original/hero-background.jpg" alt="" aria-hidden="true" loading="eager" decoding="async" />
    </div>
    <div class="hero__overlay" />
    <div class="hero__content">
      <span class="hero__tagline">Castellón · Desde 1971</span>
      <h1 class="hero__title">Asociación Juvenil Moreres</h1>
      <p class="hero__subtitle">
        Actividades familiares, formativas y deportivas. Escuela de fútbol, desde 2015.
        Un proyecto educativo para ayudar a los padres en la formación de sus hijos.
      </p>
      <div class="hero__actions">
        <a href="/quienes-somos/que-es-moreres" class="btn btn--primary btn--lg">Conoce Moreres</a>
        <a href="/escuela-deportiva" class="btn btn--secondary btn--lg">Escuela Deportiva</a>
        <a href="/galeria" class="btn btn--ghost-inverse btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Galería
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOQUE 2: FORMACIÓN INTEGRAL                -->
  <!-- ============================================ -->
  <IntegralFormationSection />

  <!-- ============================================ -->
  <!-- BLOQUE 3: DESDE 1971                         -->
  <!-- ============================================ -->
  <section class="section section--light reveal">
    <div class="container">
      <div class="history-block">
        <div class="history-block__content">
          <span class="tagline">Nuestra historia</span>
          <h2 class="history-block__title">Desde 1971 en Castellón</h2>
          <div class="separator" />
          <p class="history-block__text">
            La Asociación Moreres fue fundada en Castellón de la Plana en el año 1971. Desde sus inicios,
            hemos mantenido un firme compromiso con la juventud y las familias de la ciudad, ofreciendo
            un espacio de encuentro, formación y amistad.
          </p>
          <p class="history-block__text">
            Somos un proyecto educativo que quiere ayudar a los padres en la formación de sus hijos.
            Laicos y sacerdotes de la Prelatura del Opus Dei colaboran en esta tarea de formación
            cristiana. De ahí surgen las charlas, las meditaciones semanales y los cursos de retiro.
          </p>
          <a href="/quienes-somos" class="btn btn--outline">Conoce nuestra historia</a>
        </div>
        <div class="history-block__timeline">
          <div class="history-milestone">
            <span class="history-milestone__year">1971</span>
            <span class="history-milestone__label">Fundación</span>
          </div>
          <div class="history-milestone">
            <span class="history-milestone__year">1996</span>
            <span class="history-milestone__label">Escuela Deportiva</span>
          </div>
          <div class="history-milestone">
            <span class="history-milestone__year">2015</span>
            <span class="history-milestone__label">Relanzamiento</span>
          </div>
          <div class="history-milestone">
            <span class="history-milestone__year">2024</span>
            <span class="history-milestone__label">10º aniversario</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOQUE 4: ESCUELA DEPORTIVA                  -->
  <!-- ============================================ -->
  <section class="section reveal">
    <div class="container">
      <div class="sports-block">
        <div class="sports-block__media">
          <img src="/assets/images/supercopa-2023_orig.jpeg" alt="Supercopa Junior de Clubes 2023" loading="lazy" />
        </div>
        <div class="sports-block__content">
          <span class="tagline">C.D. Moreres</span>
          <h2 class="sports-block__title">Escuela Deportiva</h2>
          <div class="separator" />
          <p class="sports-block__text">
            La Asociación Moreres cuenta con una Escuela Deportiva de fútbol que surgió en 1996 y
            tuvo su relanzamiento en 2015. Once equipos federados y más de 185 jugadores.
          </p>
          <p class="sports-block__text">
            El C.D. Moreres tiene el objetivo de <strong>formar personas a través del deporte</strong>.
            El fútbol es una herramienta muy eficaz para trabajar valores y virtudes humanas que
            sirvan para el crecimiento personal.
          </p>
          <p class="sports-block__text">
            Contamos con un plan de formación anual con virtudes mensuales: orden, obediencia,
            compañerismo, esfuerzo, compromiso, fortaleza y respeto.
          </p>
          <div class="sports-block__actions">
            <a href="/escuela-deportiva" class="btn btn--primary">Conoce la Escuela Deportiva</a>
            <a href="/escuela-deportiva/inscripcion" class="btn btn--outline">Inscripción</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOQUE 5: VIDA EN MORERES — GALERÍA         -->
  <!-- ============================================ -->
  <section class="section section--light reveal">
    <div class="container">
      <header class="section__heading">
        <span class="tagline tagline--center">Galería</span>
        <h2 class="section__heading-title">Vida en Moreres</h2>
        <div class="separator separator--center" />
        <p class="section__heading-text">
          Así vivimos nuestras actividades, convivencias y planes. Cada curso está lleno de momentos
          que merece la pena recordar.
        </p>
      </header>

      <div class="home-gallery">
        <div class="home-gallery__item home-gallery__item--large">
          <img src="/assets/gallery/escudo-moreres-10-aniversario_orig.png" alt="Escudo 10º aniversario C.D. Moreres" loading="lazy" />
        </div>
        <div class="home-gallery__item">
          <img src="/assets/gallery/community-1.jpg" alt="Actividad grupal" loading="lazy" />
        </div>
        <div class="home-gallery__item">
          <img src="/assets/gallery/cena-de-navidad-2025-2.jpg" alt="Cena de Navidad" loading="lazy" />
        </div>
        <div class="home-gallery__item">
          <img src="/assets/gallery/convivencia-familiar-1.jpg" alt="Convivencia familiar" loading="lazy" />
        </div>
        <div class="home-gallery__item">
          <img src="/assets/gallery/familias.jpg" alt="Plan familias" loading="lazy" />
        </div>
      </div>

      <div class="home-gallery__cta">
        <a href="/galeria" class="btn btn--primary btn--lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          Ver toda la galería
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOQUE 6: PARA FAMILIAS                     -->
  <!-- ============================================ -->
  <section class="section section--dark reveal">
    <div class="container">
      <div class="families-cta">
        <h2 class="families-cta__title">¿Eres padre o madre?</h2>
        <p class="families-cta__text">
          La Asociación Moreres surge por iniciativa de las familias. Si buscas un entorno donde tus
          hijos puedan crecer en amistad, estudio, deporte y valores, este es tu sitio.
        </p>
        <p class="families-cta__text">
          Ofrecemos formación humana y cristiana para padres, planes familiares periódicos y un
          programa de virtudes trabajado en familia.
        </p>
        <div class="families-cta__actions">
          <a href="/hazte-socio" class="btn btn--primary btn--lg">Hazte socio</a>
          <a href="/contacto" class="btn btn--secondary btn--lg">Contacto</a>
          <a href="/actividades/familias" class="btn btn--ghost-inverse">
            Actividades familiares
          </a>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>

<style>
  /* ============= SECTION HEADING ============= */
  .section__heading {
    text-align: center;
    margin-bottom: var(--spacing-12);
  }

  .section__heading-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    color: var(--text-primary);
  }

  @media (min-width: 768px) {
    .section__heading-title {
      font-size: var(--text-4xl);
    }
  }

  .section__heading-text {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 640px;
    margin: 0 auto;
    line-height: var(--leading-relaxed);
  }

  /* ============= HISTORY BLOCK (Desde 1971) ============= */
  .history-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-10);
    align-items: center;
  }

  @media (min-width: 768px) {
    .history-block {
      grid-template-columns: 3fr 2fr;
    }
  }

  .history-block__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .history-block__title {
      font-size: var(--text-4xl);
    }
  }

  .history-block__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-4);
  }

  .history-block__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .history-milestone {
    display: flex;
    align-items: center;
    gap: var(--spacing-5);
    padding: var(--spacing-4) var(--spacing-6);
    background: var(--surface-white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-neutral-100);
    border-left: 4px solid var(--color-primary-500);
  }

  .history-milestone__year {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-extrabold);
    color: var(--color-primary-500);
    line-height: 1;
    min-width: 80px;
  }

  .history-milestone__label {
    font-size: var(--text-base);
    font-weight: var(--font-medium);
    color: var(--text-primary);
  }

  /* ============= SPORTS BLOCK (Escuela Deportiva) ============= */
  .sports-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .sports-block {
      grid-template-columns: 1fr 1fr;
    }
  }

  .sports-block__media img {
    width: 100%;
    border-radius: var(--radius-2xl);
    object-fit: cover;
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-xl);
  }

  .sports-block__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    color: var(--text-primary);
    margin-bottom: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .sports-block__title {
      font-size: var(--text-4xl);
    }
  }

  .sports-block__text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-4);
  }

  .sports-block__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-3);
    margin-top: var(--spacing-4);
  }

  /* ============= HOME GALLERY (Vida en Moreres) ============= */
  .home-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-3);
  }

  @media (min-width: 640px) {
    .home-gallery {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--spacing-4);
    }
  }

  .home-gallery__item {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 1;
  }

  .home-gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--easing-default);
  }

  .home-gallery__item:hover img {
    transform: scale(1.06);
  }

  .home-gallery__item--large {
    grid-column: span 2;
    grid-row: span 2;
    aspect-ratio: auto;
  }

  .home-gallery__cta {
    text-align: center;
    margin-top: var(--spacing-8);
  }

  /* ============= FAMILIES CTA (Para familias) ============= */
  .families-cta {
    text-align: center;
    max-width: 680px;
    margin: 0 auto;
  }

  .families-cta__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--text-inverse);
    margin-bottom: var(--spacing-6);
  }

  @media (min-width: 768px) {
    .families-cta__title {
      font-size: var(--text-4xl);
    }
  }

  .families-cta__text {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--spacing-4);
  }

  .families-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-4);
    justify-content: center;
    margin-top: var(--spacing-8);
  }
</style>
