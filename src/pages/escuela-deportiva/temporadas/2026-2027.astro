---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import DocBlock from "@/components/DocBlock.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Temporada 2026-2027 | Escuela Deportiva Moreres",
  description: "Revistas mensuales de la temporada 2026-2027."
}
const breadcrumbs = getBreadcrumbs("/escuela-deportiva/temporadas/2026-2027")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Temporada 2026-2027" subtitle="C.D. Moreres" breadcrumbs={breadcrumbs} />

  <Section tagline="Temporada" title="Información de la temporada 2026-2027">
    <div class="content-block">
      <p class="content-block__text">
        En el siguiente PDF se encuentra toda la información acerca de la temporada 2026-2027.
      </p>
    </div>
  </Section>

  <Section tagline="Documentos" title="Revistas y recursos" variant="light">
    <div style="display: grid; gap: var(--spacing-4); max-width: 480px;">
      <DocBlock
        name="Información temporada 2026-2027"
        href="/assets/documents/c.d._moreres_temporada_2025-2026_1.pdf"
        type="pdf"
        size="2 MB"
      />
    </div>
  </Section>
</BaseLayout>

<style>
  .content-block {
    max-width: 720px;
    margin: 0 auto;
  }
  .content-block__text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }
</style>
