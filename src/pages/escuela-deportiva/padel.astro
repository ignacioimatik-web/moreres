---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import { getBreadcrumbs } from "@data/navigation"

const route = {
  title: "Pádel | Escuela Deportiva Moreres",
  description: "Actividad de pádel los viernes en Castellón."
}
const breadcrumbs = getBreadcrumbs("/escuela-deportiva/padel")
---

<BaseLayout title={route.title} description={route.description}>
  <PageHeader title="Pádel" subtitle="Actividad deportiva semanal" breadcrumbs={breadcrumbs} />

  <Section tagline="Deporte" title="Pádel en Moreres">
    <div class="content-block">
      <p class="content-block__text">
        El Club ofrece la actividad de pádel los viernes para todos los socios que quieran
        disfrutar de este deporte en un ambiente de compañerismo y diversión.
      </p>
    </div>
  </Section>
</BaseLayout>

<style>
  .content-block {
    max-width: 640px;
    margin: 0 auto;
  }

  .content-block__text {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }
</style>
