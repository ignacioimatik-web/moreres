---
import BaseLayout from "@/layouts/BaseLayout.astro"
import PageHeader from "@/components/PageHeader.astro"
import Section from "@/components/Section.astro"
import { getBreadcrumbs } from "@data/navigation"
import { pages } from "@data/seo"

const route = pages["/contacto"]
const breadcrumbs = getBreadcrumbs("/contacto")
---

<BaseLayout title={route.title} description={route.description} breadcrumbs={breadcrumbs}>
  <PageHeader title="Contacto" subtitle="Estaremos encantados de atenderte" breadcrumbs={breadcrumbs} />

  <Section>
    <div class="contact-grid">
      <div class="contact-info">
        <h2 class="contact-info__title">Información de contacto</h2>

        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <strong>Dirección</strong><br />
            Asociación Moreres<br />
            Calle Pare Ricardo, 1<br />
            12003 Castellón de la Plana<br />
            España
          </div>
        </div>

        <div class="contact-info__item">
          <div class="contact-info__icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <strong>Email</strong><br />
            <a href="mailto:asociacionmoreres@gmail.com">asociacionmoreres@gmail.com</a>
          </div>
        </div>

        <div class="contact-info__note">
          <p>
            Si lo prefieres, puedes escribirnos directamente o utilizar el formulario
            de la derecha. Te responderemos lo antes posible.
          </p>
        </div>

        <div class="contact-info__links">
          <a href="/hazte-socio" class="btn btn--primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Quiero ser socio
          </a>
          <a href="/escuela-deportiva/inscripcion" class="btn btn--outline">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Inscripción Escuela Deportiva
          </a>
        </div>
      </div>

      <form class="contact-form" action="https://formsubmit.co/asociacionmoreres@gmail.com" method="POST">
        <input type="hidden" name="_next" value="https://asociacionmoreres.org/contacto" />
        <input type="hidden" name="_subject" value="Nuevo mensaje desde la web" />

        <div class="form-row">
          <div class="form-group">
            <label for="firstName" class="form-label">Nombre *</label>
            <input type="text" id="firstName" name="firstName" class="form-input" required placeholder="Tu nombre" />
          </div>
          <div class="form-group">
            <label for="lastName" class="form-label">Apellido *</label>
            <input type="text" id="lastName" name="lastName" class="form-input" required placeholder="Tus apellidos" />
          </div>
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Email *</label>
          <input type="email" id="email" name="email" class="form-input" required placeholder="tu@email.com" />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Texto *</label>
          <textarea id="message" name="message" class="form-textarea" required placeholder="¿En qué podemos ayudarte?" rows="5"></textarea>
        </div>

        <details class="legal-details">
          <summary class="legal-details__summary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Protección de datos
          </summary>
          <div class="legal-details__content">
            <p class="legal-text">De conformidad con la normativa vigente y aplicable en protección de datos de carácter personal, le informamos que sus datos serán incorporados al sistema de tratamiento titularidad de MORERES CLUB DEPORTIVO con CIF G12685137 y domicilio social sito en C/ CRONISTA REVEST, Nº1-BAJO 12003, CASTELLON (CASTELLÓN).</p>
            <p class="legal-text">La finalidad del tratamiento es atender sus consultas y/o solicitudes. La base legítima es el consentimiento del interesado. Los datos se conservarán mientras se mantenga el consentimiento prestado.</p>
            <p class="legal-text">Puede ejercer los derechos de acceso, rectificación, limitación de tratamiento, supresión, portabilidad y oposición dirigiendo su petición a la dirección postal o al correo electrónico <a href="mailto:asociacionmoreres@gmail.com">asociacionmoreres@gmail.com</a>. Puede dirigirse a la Autoridad de Control competente para presentar la reclamación que considere oportuna.</p>
            <p class="legal-text">Con el envío del formulario usted acepta la política de privacidad de MORERES CLUB DEPORTIVO.</p>
            <p class="legal-text"><a href="/legal/politica-de-privacidad">Ver política de privacidad completa</a></p>
          </div>
        </details>

        <button type="submit" class="btn btn--primary btn--lg btn--full">
          Enviar mensaje
        </button>
      </form>
    </div>
  </Section>

  <Section variant="light" tagline="Ubicación" title="Cómo llegar" center>
    <div class="map-wrapper">
      <iframe
        src="https://www.openstreetmap.org/export/embed.html?bbox=-0.009%2C39.978%2C-0.003%2C39.982&layer=mapnik&marker=39.980%2C-0.006"
        width="100%"
        height="400"
        style="border: none; border-radius: var(--radius-2xl);"
        title="Mapa de Castellón"
        loading="lazy"
        referrerpolicy="no-referrer"
      />
      <p class="map-caption">
        <a href="https://www.openstreetmap.org/?mlat=39.980&mlon=-0.006#map=16/39.980/-0.006" target="_blank" rel="noopener noreferrer">
          Ver mapa más grande en OpenStreetMap
        </a>
      </p>
    </div>
  </Section>

  <Section variant="dark" center>
    <div class="cta-section">
      <h2 class="cta-section__title">¿Quieres formar parte de Moreres?</h2>
      <p class="cta-section__text">
        Si compartes nuestros valores y quieres participar en las actividades del Club,
        te invitamos a hacerte socio o conocer nuestra Escuela Deportiva.
      </p>
      <div class="cta-section__actions">
        <a href="/hazte-socio" class="btn btn--primary btn--lg">Hazte socio</a>
        <a href="/escuela-deportiva" class="btn btn--secondary btn--lg">Escuela Deportiva</a>
        <a href="/contacto" class="btn btn--secondary btn--lg">Contacto</a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-12);
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1.5fr;
    }
  }

  .contact-info__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    margin-bottom: var(--spacing-6);
    color: var(--text-primary);
  }

  .contact-info__item {
    display: flex;
    gap: var(--spacing-4);
    margin-bottom: var(--spacing-5);
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
  }

  .contact-info__item strong {
    color: var(--text-primary);
  }

  .contact-info__icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-50);
    border-radius: var(--radius-lg);
    color: var(--color-primary-600);
  }

  .contact-info__note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--spacing-6);
    padding-top: var(--spacing-4);
    border-top: 1px solid var(--color-neutral-100);
  }

  .contact-info__links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .contact-info__links .btn svg {
    width: 1.125rem;
    height: 1.125rem;
  }

  .contact-form {
    background: var(--surface-white);
    padding: var(--spacing-8);
    border-radius: var(--radius-2xl);
    border: 1px solid var(--color-neutral-100);
    box-shadow: var(--shadow-md);
  }

  @media (min-width: 768px) {
    .contact-form {
      padding: var(--spacing-10);
    }
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-4);
    }
  }

  .map-wrapper {
    max-width: 720px;
    margin: 0 auto;
  }

  .map-caption {
    margin-top: var(--spacing-3);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .map-caption a {
    color: var(--color-primary-600);
    text-decoration: underline;
  }

  .cta-section__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--text-inverse);
    margin-bottom: var(--spacing-4);
  }

  @media (min-width: 768px) {
    .cta-section__title {
      font-size: var(--text-4xl);
    }
  }

  .cta-section__text {
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.85);
    max-width: 560px;
    margin: 0 auto var(--spacing-8);
    line-height: var(--leading-relaxed);
  }

  .cta-section__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-4);
  }
</style>
